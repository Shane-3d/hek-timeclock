# Local configuration for the HEK timeclock. This file is NOT committed to git.
# Edit these values to configure the app when running with `npm start`.

# ---- Cloud database (REQUIRED) --------------------------------------------
# Paste the PostgreSQL connection string from your provider (Neon, Supabase,
# Render, Railway, etc.). The server will NOT start until this is filled in.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=mongodb+srv://shanevandekrol:golfcart@hektimeclock.2n9uuxp.mongodb.net/?appName=hektimeclock

# SSL is ON by default (cloud Postgres needs it). Set to "false" only for a
# local database that doesn't use SSL.
# DATABASE_SSL=false

# ---- Admin access ----------------------------------------------------------
# Email + password you type on the admin login page.
ADMIN_EMAIL=admin@hekfencing.com
ADMIN_PASSWORD=fence

# Timezone used to decide when a workday ends (for detecting missed clock-outs).
# Use an IANA name, e.g. America/New_York, America/Toronto, America/Chicago.
TIMEZONE=America/New_York

# Random string used to sign the login cookie. Make it long and random.
SESSION_SECRET=change-this-to-a-long-random-string

# URL path for the admin login page (not "/admin", not linked from the crew's
# page). With this setting the admin login is at:  http://localhost:3000/fence
ADMIN_PATH=/fence

# Port the server listens on.
PORT=3000
