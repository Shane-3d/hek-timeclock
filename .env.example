# Copy this file to ".env" (locally) or set these as environment variables on your host.

# ---- Cloud database (REQUIRED) --------------------------------------------
# Paste the MongoDB connection string from your provider (e.g. MongoDB Atlas).
# The app stores ALL data here — nothing on the server.
# Example: mongodb+srv://user:password@cluster.mongodb.net/?appName=yourapp
DATABASE_URL=

# Name of the database to use inside the cluster (created automatically).
# DB_NAME=hektimeclock

# ---- Admin access ----------------------------------------------------------
# Email admins type to sign in to the dashboard.
ADMIN_EMAIL=admin@hekfencing.com

# Password admins type to reach the dashboard. CHANGE THIS.
ADMIN_PASSWORD=fence

# Timezone used to decide when a workday ends (for detecting missed clock-outs).
# Use an IANA name, e.g. America/New_York, America/Toronto, America/Chicago.
TIMEZONE=America/New_York

# Random string used to sign the login cookie. Make it long and random.
SESSION_SECRET=change-this-to-a-long-random-string

# URL path for the admin dashboard. Admins sign in on the main page ("/") and are
# redirected here automatically, so it isn't linked from the employee page.
ADMIN_PATH=/admin

# Port the server listens on (most hosts set this for you).
PORT=3000
